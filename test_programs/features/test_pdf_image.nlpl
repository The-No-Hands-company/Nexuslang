print text "  - pdf_add_page(canvas_id)"
print text "  - pdf_save(canvas_id)"

print text "PDF reading functions available:"
print text "  - pdf_open(filename)"
print text "  - pdf_get_page_count(reader_id)"
print text "  - pdf_extract_text(reader_id, page_number)"
print text "  - pdf_get_metadata(reader_id)"
print text "  - pdf_close(reader_id)"

print text "PDF manipulation functions available:"
print text "  - pdf_merge(output_filename, input_files)"
print text "  - pdf_split_pages(input_filename, start_page, end_page, output_filename)"
print text "  - pdf_rotate_page(input_filename, page_number, rotation, output_filename)"
print text "  - pdf_encrypt(input_filename, output_filename, password)"

