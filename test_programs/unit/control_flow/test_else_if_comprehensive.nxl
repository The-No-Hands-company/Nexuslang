# Comprehensive else-if test
print text "=== Test 1: Score 95 ==="
set score to 95
if score is greater than or equal to 90
    print text "Grade: A"
else if score is greater than or equal to 80
    print text "Grade: B"
else if score is greater than or equal to 70
    print text "Grade: C"
else
    print text "Grade: F"
end

