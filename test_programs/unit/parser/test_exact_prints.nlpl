print text "=== Generic Types in NLPL ==="
print text ""

print text "1. Generic Container Class"
print text "--------------------------"

class Box<T>
    property value as T
    
    method get_value returns T
        return this.value
    end method
end class

set int_box to new Box<Integer>
set int_box.value to 42

print text "Integer box value: "
print text call int_box.get_value
