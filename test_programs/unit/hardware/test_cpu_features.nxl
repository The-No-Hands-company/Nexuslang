set has_avx512f to check_feature with feature_name: "avx512f"
if has_avx512f
    print text "AVX-512 Foundation: Available"
else
    print text "AVX-512: Not available"
end

# Test 4: Cryptography features
print text "Test 4: Cryptography features"

set has_aes to check_feature with feature_name: "aes"
if has_aes is equal to true
    print text "AES-NI: Supported"
else
    print text "AES-NI: Not supported"
end

set has_pclmulqdq to check_feature with feature_name: "pclmulqdq"
if has_pclmulqdq is equal to true
    print text "PCLMULQDQ: Supported"
else
    print text "PCLMULQDQ: Not supported"
end

set has_rdrand to check_feature with feature_name: "rdrand"
if has_rdrand is equal to true
    print text "RDRAND: Supported"
else
