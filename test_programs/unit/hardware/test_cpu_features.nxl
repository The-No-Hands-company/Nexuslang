# Test 9: Power management
print text "Test 9: Power/monitoring features"

set has_monitor to check_feature with feature_name: "monitor"
print text "MONITOR/MWAIT:"
print text has_monitor

# Test 10: Feature summary for optimization decisions
print text "Test 10: Optimization recommendations"

set features_final to get_cpu_features()

# Vector optimization recommendation
print text "Vector optimization:"
if features_final["has_avx2"]
    print text "  Use AVX2 (256-bit SIMD)"
else
    if features_final["has_avx"]
        print text "  Use AVX (256-bit SIMD)"
    else
        if features_final["has_sse4_2"]
            print text "  Use SSE4.2 (128-bit SIMD)"
        else
            if features_final["has_sse2"]
                print text "  Use SSE2 (128-bit SIMD)"
            else
                print text "  Use scalar operations"
            end
        end
    end
end

# Crypto recommendation
print text "Crypto acceleration:"
if features_final["has_aes"]
    print text "  Use AES-NI instructions"
else
    print text "  Use software AES"
end

print text "Test complete"
