# CPU Feature Detection Test  
# Test: Comprehensive feature detection
# Expected: Should detect all CPU capabilities

print text "Test: CPU Feature Detection"

# Test 1: Get comprehensive feature dict
print text "Test 1: Get all features"
set all_features to get_cpu_features()
print text "Total features detected:"
print text "Basic flags (EDX):"
print text all_features["basic"]
print text "Extended flags (ECX):"
print text all_features["extended"]

# Test 2: Floating point and math
print text "Test 2: Math features"
set has_fpu to check_feature with feature_name: "fpu"
print text "FPU (Floating Point Unit):"
print text has_fpu

set has_fma to check_feature with feature_name: "fma"
print text "FMA (Fused Multiply-Add):"
print text has_fma

set has_f16c to check_feature with feature_name: "f16c"
print text "F16C (Half-precision float):"
print text has_f16c

# Test 3: SIMD instruction sets
print text "Test 3: SIMD instruction sets"

# MMX
set has_mmx to check_feature with feature_name: "mmx"
if has_mmx is equal to true
    print text "MMX: Available"
else
    print text "MMX: Not available"
end

# SSE family
set has_sse to check_feature with feature_name: "sse"
if has_sse is equal to true
    print text "SSE: Available"
else
    print text "SSE: Not available"
end

set has_sse2 to check_feature with feature_name: "sse2"
