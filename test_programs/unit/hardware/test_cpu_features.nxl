    print text "SSE3: Available"
else
    print text "SSE3: Not available"
end

set has_ssse3 to check_feature with feature_name: "ssse3"
if has_ssse3
    print text "SSSE3: Available"
else
    print text "SSSE3: Not available"
end

set has_sse4_1 to check_feature with feature_name: "sse4_1"
if has_sse4_1
    print text "SSE4.1: Available"
else
    print text "SSE4.1: Not available"
end

set has_sse4_2 to check_feature with feature_name: "sse4_2"
if has_sse4_2
    print text "SSE4.2: Available"
else
    print text "SSE4.2: Not available"
end

# AVX family
set has_avx to check_feature with feature_name: "avx"
if has_avx is equal to true
    print text "AVX: Available"
else
    print text "AVX: Not available"
end

set has_avx2 to check_feature with feature_name: "avx2"
if has_avx2
    print text "AVX2: Available"
else
    print text "AVX2: Not available"
