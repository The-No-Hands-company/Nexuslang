print text ""

# Test 5: Read IA32_GS_BASE
print text "Test 5: Read IA32_GS_BASE"
function test_read_gs_base
    set gs_base_addr to 3221225729  # 0xC0000101
    set gs_base to read_msr with msr_address: gs_base_addr
    print text "GS BASE:"
    print text gs_base
end

try
    test_read_gs_base
catch error
