# CPU Model-Specific Registers (MSR) Test
# Test: MSR read/write operations
# Expected: Error messages indicating compiled mode required
# NOTE: MSR access requires compiled mode with inline assembly

print text "Test: Model-Specific Registers (MSRs)"
print text "NOTE: MSR access requires compiled mode"
print text ""

# Test 1: Read IA32_EFER (Extended Feature Enable Register)
print text "Test 1: Read IA32_EFER"
function test_read_efer
    set efer_addr to 3221225600  # 0xC0000080
    set efer to read_msr with msr_address: efer_addr
    print text "EFER value:"
    print text efer
end

try
    test_read_efer
catch error
    print text "Expected error: MSR read requires compiled mode"
    print text error
end

print text ""

# Test 2: Read IA32_APIC_BASE
print text "Test 2: Read IA32_APIC_BASE"
function test_read_apic_base
    set apic_addr to 27  # 0x1B
    set apic_base to read_msr with msr_address: apic_addr
    print text "APIC BASE:"
    print text apic_base
end

try
    test_read_apic_base
catch error
    print text "Expected error: MSR read requires compiled mode"
    print text error
end

print text ""

# Test 3: Read IA32_TSC (Time Stamp Counter)
print text "Test 3: Read IA32_TSC"
function test_read_tsc
    set tsc_addr to 16  # 0x10
    set tsc to read_msr with msr_address: tsc_addr
    print text "TSC value:"
    print text tsc
end

try
    test_read_tsc
catch error
    print text "Expected error: MSR read requires compiled mode"
    print text error
end

print text ""

