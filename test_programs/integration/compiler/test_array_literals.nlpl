# Test Array Literals in Various Contexts

# Test 1: Simple integer array literal
set numbers to [1, 2, 3, 4, 5]
print text "First number: "
print text numbers[0]
print text "\n"

# Test 2: Float array literal
set floats to [3.14, 2.71, 1.41]
print text "First float: "
print text floats[0]
print text "\n"

# Test 3: String array literal  
set words to ["hello", "world", "test"]
print text "First word: "
print text words[0]
print text "\n"

# Test 4: Boolean array literal
set flags to [true, false, true]
print text "First flag: "
print text flags[0]
print text "\n"

# Test 5: Empty array
set empty to []
print text "Empty array created\n"

# Test 6: Nested array (2D array)
set matrix to [[1, 2], [3, 4]]
print text "Matrix element [0][0]: "
print text matrix[0][0]
print text "\n"

print text "Array literals test complete!\n"
