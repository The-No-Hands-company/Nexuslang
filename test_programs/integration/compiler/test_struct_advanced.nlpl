# Advanced Struct Features Test

# Test 1: Nested Structs
struct Point
    x as Integer
    y as Integer

struct Rectangle
    top_left as Point
    bottom_right as Point

print text "Test 1: Nested Structs"
set rect to new Rectangle
set rect.top_left to new Point
set rect.bottom_right to new Point

set rect.top_left.x to 10
set rect.top_left.y to 20
set rect.bottom_right.x to 100
set rect.bottom_right.y to 200

print text "Top-left: "
print number rect.top_left.x
print number rect.top_left.y
print text "Bottom-right: "
print number rect.bottom_right.x
print number rect.bottom_right.y
print text ""

# Test 2: Struct Pointers
print text "Test 2: Struct Pointers"
set p1 to new Point
set p1.x to 50
set p1.y to 75

set p_ptr to address of p1
set p2 to value at p_ptr
print text "Via pointer: "
print number p2.x
print number p2.y
print text ""

# Test 3: Struct with Mixed Types
struct Person
    age as Integer
    height as Float
    weight as Float

print text "Test 3: Mixed Types"
set person to new Person
set person.age to 30
set person.height to 5.9
set person.weight to 165.5

print number person.age
print number person.height
print number person.weight
print text ""

# Test 4: Struct Arrays - Currently testing basic struct only
# (Full struct array support will be added when array of structs indexing is implemented)
print text "Test 4: Struct Arrays (Basic)"
set p_arr_1 to new Point
set p_arr_1.x to 11
set p_arr_1.y to 22
print number p_arr_1.x
print number p_arr_1.y
print text ""

# Test 5: Passing Struct to Function - Simplified (parameters will be enhanced later)
# Currently functions don't support struct parameters in compiler
print text "Test 5: Struct Function (Manual)"
set test_point to new Point
set test_point.x to 42
set test_point.y to 99
print text "Test point coordinates:"
print number test_point.x
print number test_point.y
print text ""

# Test 6: Returning Struct from Function - Simplified
# Function return types currently limited to primitives in compiler
print text "Test 6: Struct Creation and Assignment"
set origin to new Point
set origin.x to 0
set origin.y to 0
print number origin.x
print number origin.y

print text "All advanced struct tests complete!"
