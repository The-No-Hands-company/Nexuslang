# Test explicit this.property

class Box
    property value as Integer
    
    method set_value with n as Integer returns Integer
        set this.value to n
        return this.value
    
    method add_to_value with n as Integer returns Integer
        set this.value to this.value plus n
        return this.value

set b to new Box
set b.value to 10
print text "Initial:"
print number b.value

set r1 to call b.set_value with 20
print text "After set_value(20):"
print number r1
print number b.value

set r2 to call b.add_to_value with 5
print text "After add_to_value(5):"
print number r2
print number b.value
