# Test errno module (C errno.h equivalent)

print text "Testing NexusLang Error Numbers Module (C errno.h)"
print text "=============================================="
print text ""

print text "Error Management:"
print text "- errno_get: Get current errno value"
print text "- errno_set: Set errno value"
print text "- errno_clear: Clear errno (set to 0)"
print text "- errno_strerror: Get error message for error number"
print text "- errno_perror: Print error message to stderr"
print text ""

print text "Standard POSIX Error Constants:"
print text "- errno_EPERM: Operation not permitted (1)"
print text "- errno_ENOENT: No such file or directory (2)"
print text "- errno_ESRCH: No such process (3)"
print text "- errno_EINTR: Interrupted system call (4)"
print text "- errno_EIO: I/O error (5)"
print text "- errno_EBADF: Bad file number (9)"
print text "- errno_ENOMEM: Out of memory (12)"
print text "- errno_EACCES: Permission denied (13)"
print text "- errno_EBUSY: Device or resource busy (16)"
print text "- errno_EEXIST: File exists (17)"
print text "- errno_ENOTDIR: Not a directory (20)"
print text "- errno_EISDIR: Is a directory (21)"
print text "- errno_EINVAL: Invalid argument (22)"
print text "- errno_EMFILE: Too many open files (24)"
print text "- errno_ENOSPC: No space left on device (28)"
print text "- errno_EPIPE: Broken pipe (32)"
print text ""

print text "Network Error Constants:"
print text "- errno_EWOULDBLOCK: Operation would block (11)"
print text "- errno_EINPROGRESS: Operation in progress (115)"
print text "- errno_EADDRINUSE: Address already in use (98)"
print text "- errno_ECONNREFUSED: Connection refused (111)"
print text "- errno_ETIMEDOUT: Connection timed out (110)"
print text "- errno_ENETUNREACH: Network unreachable (101)"
print text "- errno_ECONNRESET: Connection reset by peer (104)"
print text "- errno_EHOSTUNREACH: No route to host (113)"
print text ""

print text "Example Usage:"
print text "-------------"
print text "# Set errno when error occurs"
print text "errno_set with errno_ENOENT()"
print text ""
print text "# Get error message"
print text "set msg to errno_strerror with errno_ENOENT()"
print text "print text msg # \"No such file or directory\""
print text ""
print text "# Check current errno"
print text "set current to errno_get()"
print text "if current equals errno_ENOENT()"
print text " print text \"File not found error\""
print text ""
print text "# Clear errno after handling"
print text "errno_clear()"
print text ""

print text "Summary:"
print text "--------"
print text " 50+ error number constants"
print text " Complete C errno.h coverage"
print text " Standard POSIX errors (ENOENT, EACCES, EINVAL, etc.)"
print text " Network errors (ETIMEDOUT, ECONNREFUSED, etc.)"
print text " Error message lookup (strerror)"
print text " Global errno state management"
print text ""
print text "Essential for:"
print text "- Error handling and reporting"
print text "- System call error checking"
print text "- Network programming"
print text "- File I/O operations"
print text "- POSIX-compliant error codes"
