# Test switch statement with multiple cases

set day to 3

switch day
    case 1
        print text "Monday"
    case 2
        print text "Tuesday"
    case 3
        print text "Wednesday"
    case 4
        print text "Thursday"
    case 5
        print text "Friday"
    default
        print text "Weekend"

print text "After switch"

# Test with string values
set color to "red"

switch color
    case "red"
        print text "Stop"
    case "yellow"
        print text "Caution"
    case "green"
        print text "Go"
    default
        print text "Unknown color"

print text "All switch tests completed!"
