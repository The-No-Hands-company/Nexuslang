# Test database connectors module
# Tests PostgreSQL, MySQL, and MongoDB database support

print text "=== Database Connectors Test ==="
print text ""

# Test PostgreSQL availability
print text "Testing PostgreSQL support..."
print text "PostgreSQL connector module loaded"
print text "Available functions:"
print text "  - pg_connect(host, port, database, user, password, pool_size)"
print text "  - pg_execute(pool_id, query, params) - INSERT/UPDATE/DELETE"
print text "  - pg_query(pool_id, query, params) - SELECT returning rows"
print text "  - pg_query_one(pool_id, query, params) - SELECT returning one row"
print text "  - pg_close(pool_id) - Close connection pool"
print text ""

# Test MySQL availability
print text "Testing MySQL support..."
print text "MySQL connector module loaded"
print text "Available functions:"
print text "  - mysql_connect(host, port, database, user, password, pool_size, pool_name)"
print text "  - mysql_execute(pool_name, query, params) - INSERT/UPDATE/DELETE"
print text "  - mysql_query(pool_name, query, params) - SELECT returning rows"
print text "  - mysql_query_one(pool_name, query, params) - SELECT returning one row"
print text "  - mysql_close(pool_name) - Close connection pool"
print text ""

