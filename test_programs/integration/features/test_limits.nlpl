# Test numeric limits (limits.h/float.h equivalent)

print text "Testing NLPL Numeric Limits Module (C limits.h/float.h)"
print text "========================================================"
print text ""

print text "Character Limits:"
print text "- limits_CHAR_BIT: Bits in a char (8)"
print text "- limits_CHAR_MIN: Min signed char (-128)"
print text "- limits_CHAR_MAX: Max signed char (127)"
print text "- limits_UCHAR_MAX: Max unsigned char (255)"
print text ""

print text "Integer Limits:"
print text "- limits_SHRT_MIN/MAX: Short int limits (16-bit)"
print text "- limits_INT_MIN/MAX: Int limits (32-bit)"
print text "- limits_LONG_MIN/MAX: Long int limits (64-bit)"
print text "- limits_LLONG_MIN/MAX: Long long limits (64-bit)"
print text "- Unsigned variants: USHRT_MAX, UINT_MAX, ULONG_MAX, ULLONG_MAX"
print text ""

print text "Floating Point Limits (IEEE 754):"
print text "- limits_FLT_EPSILON: Smallest x where 1.0 + x != 1.0"
print text "- limits_FLT_MIN: Minimum normalized float"
print text "- limits_FLT_MAX: Maximum finite float"
print text "- limits_DBL_EPSILON: Double epsilon"
print text "- limits_DBL_MIN: Minimum normalized double"
print text "- limits_DBL_MAX: Maximum finite double"
print text ""

print text "Platform Information:"
print text "- limits_get_word_size: Platform word size (32 or 64)"
print text "- limits_is_little_endian: Check byte order"
print text "- limits_get_pointer_size: Pointer size in bytes"
print text "- limits_get_alignment: Get type alignment"
print text "- limits_get_size: Get type size"
print text ""

print text "Example Usage:"
print text "-------------"
print text "# Integer limits"
print text "set max_int to limits_INT_MAX() # 2147483647"
print text "set min_int to limits_INT_MIN() # -2147483648"
print text ""
print text "# Float limits"
print text "set epsilon to limits_FLT_EPSILON() # ~1.19e-07"
print text "set max_float to limits_FLT_MAX() # ~3.40e+38"
print text ""
print text "# Platform info"
print text "set word_size to limits_get_word_size() # 32 or 64"
print text "set is_le to limits_is_little_endian() # True on x86"
print text ""
print text "# Get all limits at once"
print text "set all to limits_get_all_limits()"
print text ""

print text "Summary:"
print text "--------"
print text " 35+ numeric limit constants and functions"
print text " Complete C limits.h and float.h coverage"
print text " Character limits (CHAR_BIT, CHAR_MIN/MAX, UCHAR_MAX)"
print text " Integer limits (SHORT, INT, LONG, LLONG with signed/unsigned)"
print text " Float limits (FLT/DBL EPSILON, MIN, MAX)"
print text " Platform info (word size, endianness, pointer size)"
print text " Type info (alignment, size)"
print text ""
print text "Critical for:"
print text "- Portable numeric code"
print text "- Overflow/underflow checking"
print text "- Floating point comparisons"
print text "- Cross-platform development"
print text "- Low-level memory operations"
