# Test character classification (ctype.h equivalent)

print text "Testing NexusLang Character Classification Module (C ctype.h)"
print text "========================================================="
print text ""

print text "Character Classification:"
print text "- char_isalpha: Check if alphabetic (a-z, A-Z)"
print text "- char_isdigit: Check if decimal digit (0-9)"
print text "- char_isalnum: Check if alphanumeric"
print text "- char_isspace: Check if whitespace"
print text "- char_isupper: Check if uppercase letter"
print text "- char_islower: Check if lowercase letter"
print text "- char_isprint: Check if printable"
print text "- char_ispunct: Check if punctuation"
print text "- char_iscntrl: Check if control character"
print text "- char_isxdigit: Check if hex digit (0-9, a-f, A-F)"
print text "- char_isascii: Check if ASCII (0-127)"
print text ""

print text "Case Conversion:"
print text "- char_toupper: Convert to uppercase"
print text "- char_tolower: Convert to lowercase"
print text ""

print text "Character Code Operations:"
print text "- char_ord: Get Unicode code point"
print text "- char_chr: Create character from code point"
print text "- char_toascii: Convert to ASCII (mask to 7 bits)"
print text ""

print text "Example Usage:"
print text "-------------"
print text "# Classification"
print text "set is_letter to char_isalpha with \"A\" # True"
print text "set is_number to char_isdigit with \"5\" # True"
print text "set is_hex to char_isxdigit with \"F\" # True"
print text ""
print text "# Case conversion"
print text "set upper to char_toupper with \"hello\" # \"HELLO\""
print text "set lower to char_tolower with \"WORLD\" # \"world\""
print text ""
print text "# Character codes"
print text "set code to char_ord with \"A\" # 65"
print text "set char to char_chr with 65 # \"A\""
print text ""

print text "Summary:"
print text "--------"
print text " 16 character classification/conversion functions"
print text " Complete C ctype.h equivalent"
print text " Unicode-aware operations"
print text " Classification: alpha, digit, alnum, space, upper, lower, print, punct, cntrl, xdigit, ascii"
print text " Conversion: toupper, tolower, toascii"
print text " Character codes: ord, chr"
print text ""
print text "Essential for:"
print text "- String parsing and validation"
print text "- Text processing"
print text "- Lexical analysis"
print text "- Input validation"
