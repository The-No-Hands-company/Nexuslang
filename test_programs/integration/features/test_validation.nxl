# Test validation module

print text "Testing NexusLang Validation Module"
print text "=============================="
print text ""

# Type validation
print text "Type Validation Functions:"
print text "- validate_type: Check if value matches expected type"
print text " Types: string, integer, float, boolean, list, dict, none"
print text "- validate_range: Check if number is within min/max"
print text "- validate_length: Check string/list/dict length"
print text ""

# Pattern validation
print text "Pattern Validation:"
print text "- validate_pattern: Match value against regex"
print text "- validate_email: Validate email format"
print text "- validate_url: Validate URL format (http/https)"
print text ""

# Required fields validation
print text "Field Validation:"
print text "- validate_required: Check if all required fields present in dict"
print text " Returns: {valid: bool, missing: [field_names]}"
print text ""

# List validation
print text "List Validation:"
print text "- validate_not_empty: Check if list/string is not empty"
print text "- validate_in_list: Check if value is in allowed list"
print text "- validate_unique: Check if all list elements are unique"
print text ""

# Schema validation
print text "Schema Validation:"
print text "- validate_schema: Validate data against complex schema"
print text " Schema rules: type, required, min, max, min_length, max_length, pattern, choices"
print text " Returns: {valid: bool, errors: [error_messages]}"
print text ""

# Sanitization
print text "Sanitization Functions:"
print text "- sanitize_string: Filter allowed characters with regex"
print text " Default: alphanumeric + spaces"
print text "- sanitize_html: Escape HTML special characters"
print text " Escapes: angle brackets, ampersand, quotes"
print text ""

print text "Example Usage:"
print text "-------------"
print text "# Type validation"
print text "set valid to validate_type with \"hello\" and \"string\""
print text ""
print text "# Email validation"
print text "set valid_email to validate_email with \"user@example.com\""
print text ""
print text "# Schema validation"
print text "set schema to {\"name\": {\"type\": \"string\", \"required\": true}}"
print text "set data to {\"name\": \"John\"}"
print text "set result to validate_schema with data and schema"
print text ""
print text "# Sanitization"
print text "set clean to sanitize_html with \"<script>alert('xss')</script>\""
print text ""

print text "Summary:"
print text "--------"
print text " 13 validation and sanitization functions"
print text " Type validation for 7 types"
print text " Pattern matching (regex, email, URL)"
print text " Schema validation with 8 rule types"
print text " List validation (empty, in_list, unique)"
print text " HTML and string sanitization"
print text ""
print text "Security Features:"
print text "- SQL injection prevention (via type validation)"
print text "- XSS prevention (HTML escaping)"
print text "- Input validation for APIs"
print text "- Data integrity checks"
