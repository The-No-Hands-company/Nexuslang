print text "- algo_unique_all: Remove all duplicates"
print text "- algo_partition: Partition by predicate"
print text ""

print text "Aggregation Algorithms:"
print text "- algo_accumulate: Accumulate with operation"
print text "- algo_reduce: Reduce to single value"
print text "- algo_min_element: Find minimum"
print text "- algo_max_element: Find maximum"
print text "- algo_minmax_element: Find both min and max"
print text ""

print text "Transformation Algorithms:"
print text "- algo_transform: Apply function to each element"
print text "- algo_map: Map function over list"
print text "- algo_filter: Filter by predicate"
print text ""

print text "Counting Algorithms:"
print text "- algo_count: Count occurrences"
print text "- algo_count_if: Count with predicate"
print text ""

print text "Predicate Algorithms:"
print text "- algo_all_of: Check if all satisfy predicate"
