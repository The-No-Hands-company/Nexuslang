# Test bit manipulation operations

print text "Testing NLPL Bit Operations Module (ASM/C Essential)"
print text "====================================================="
print text ""

print text "Bitwise Logical Operations:"
print text "- bit_and: Bitwise AND"
print text "- bit_or: Bitwise OR"
print text "- bit_xor: Bitwise XOR (exclusive OR)"
print text "- bit_not: Bitwise NOT (inversion)"
print text ""

print text "Bit Shifts:"
print text "- bit_shl: Shift left (logical)"
print text "- bit_shr: Shift right (logical)"
print text "- bit_asr: Arithmetic shift right (preserves sign)"
print text ""

print text "Bit Rotation:"
print text "- bit_rol: Rotate left (circular shift)"
print text "- bit_ror: Rotate right (circular shift)"
print text ""

print text "Bit Counting:"
print text "- bit_popcount: Count set bits (1s)"
print text "- bit_clz: Count leading zeros"
print text "- bit_ctz: Count trailing zeros"
print text ""

print text "Bit Manipulation:"
print text "- bit_set: Set bit at position to 1"
print text "- bit_clear: Clear bit at position to 0"
print text "- bit_toggle: Toggle bit at position"
print text "- bit_test: Test if bit is set"
print text ""

print text "Bit Field Operations:"
print text "- bit_extract: Extract bit field"
print text "- bit_insert: Insert bit field"
print text ""

print text "Advanced Operations:"
print text "- bit_reverse: Reverse bit order"
print text "- bit_parity: Calculate parity (even/odd)"
print text "- bit_swap_bytes: Swap byte order (endianness)"
print text ""

print text "Example Usage:"
print text "-------------"
print text "# Bitwise operations"
print text "set mask to bit_and with 0xFF and 0x0F  # Result: 0x0F"
print text "set flags to bit_or with 0x01 and 0x02  # Result: 0x03"
print text ""
print text "# Bit shifts (common in ASM/C)"
print text "set shifted to bit_shl with 1 and 4  # 1 << 4 = 16"
print text "set shifted to bit_shr with 16 and 2  # 16 >> 2 = 4"
print text ""
print text "# Bit rotation (ASM ROL/ROR)"
print text "set rotated to bit_rol with 0x80 and 1 and 8  # Rotate left in 8-bit"
print text ""
print text "# Bit counting (useful for algorithms)"
print text "set count to bit_popcount with 0xFF  # Count 1s = 8"
print text "set zeros to bit_clz with 0x0F and 32  # Leading zeros in 32-bit"
print text ""
print text "# Bit field extraction (common in hardware)"
print text "set field to bit_extract with 0xABCD and 4 and 8  # Extract middle byte"
print text ""

print text "Summary:"
print text "--------"
print text "✓ 20 bit manipulation functions"
print text "✓ Complete ASM/C bitwise operation coverage"
print text "✓ AND, OR, XOR, NOT, shifts, rotations"
print text "✓ Bit counting (popcount, clz, ctz)"
print text "✓ Bit field operations (extract, insert)"
print text "✓ Advanced operations (reverse, parity, endian swap)"
print text ""
