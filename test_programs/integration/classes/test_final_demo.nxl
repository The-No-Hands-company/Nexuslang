class Person
    property name as String
    property age as Integer
    
    method greet
        print "Hello, my name is"
        print name
    
    method celebrate
        print "Happy birthday!"
        set age to age plus 1
        print "Now I am"
        print age

set person to new Person
set person.name to "Alice"
set person.age to 29

person.greet()
person.celebrate()
