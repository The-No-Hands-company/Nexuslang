# Comprehensive Type System Test
# Tests type checking, type inference, and error detection

print text "=== Type System Comprehensive Test ==="
print text ""

# Test 1: Type Inference for variables
print text "Test 1: Variable Type Inference"
set integer_var to 42
set float_var to 3.14
set string_var to "Hello NLPL"
set bool_var to true
print text " Variables created with inferred types"
print text ""

# Test 2: Arithmetic operations with type checking
print text "Test 2: Arithmetic Operations"
set sum to integer_var plus 10
set product to integer_var times 2
set division to float_var divided by 2
print text "42 + 10 ="
print text sum
print text "42 * 2 ="
print text product 
print text "3.14 / 2 ="
print text division
print text " Arithmetic operations passed"
print text ""

# Test 3: String operations
print text "Test 3: String Operations"
set greeting to "Hello" plus " " plus "World"
print text greeting
print text " String concatenation passed"
print text ""

# Test 4: Comparison operations
print text "Test 4: Comparison Operations"
if integer_var is greater than 40
 print text " Comparison (42 > 40) is true"

if integer_var is less than 50
 print text " Comparison (42 < 50) is true"

print text ""

# Test 5: Boolean operations
print text "Test 5: Boolean Operations"
set condition1 to true
set condition2 to false
if condition1 and not condition2
 print text " Boolean logic (true AND NOT false) passed"

print text ""

print text "=== All Tests Passed! ==="
print text "Type checking, type inference, and operations working correctly."
