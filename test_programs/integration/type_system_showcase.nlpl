# Type System Feature Showcase
# Demonstrates the complete type system functionality

print text "=========================================="
print text "NLPL Type System Feature Showcase"
print text "=========================================="
print text ""

# Feature 1: Type Inference
print text "Feature 1: Automatic Type Inference"
print text "------------------------------------"
set integer_val to 42
set float_val to 3.14159
set string_val to "NLPL Programming"
set bool_val to true
print text " Variables created with automatic type inference"
print text " integer_val: 42"
print text " float_val: 3.14159" 
print text " string_val: NLPL Programming"
print text " bool_val: true"
print text ""

# Feature 2: Type-Safe Arithmetic
print text "Feature 2: Type-Safe Arithmetic Operations"
print text "------------------------------------------"
set sum to integer_val plus 8
set product to integer_val times 2
set division to float_val divided by 2
print text " Arithmetic with type checking:"
print text " 42 + 8 = 50"
print text " 42 * 2 = 84"
print text " 3.14159 / 2 = 1.570795"
print text ""

# Feature 3: Typed Function Parameters
print text "Feature 3: Typed Function Parameters"
print text "------------------------------------"
function multiply with x as Integer, y as Integer returns Integer
 return x times y
end

set result to multiply(6, 7)
print text " Function with typed parameters:"
print text " multiply(6, 7) = 42"
print text ""

# Feature 4: String Operations
print text "Feature 4: Type-Safe String Operations"
print text "--------------------------------------"
set greeting to "Hello" plus " " plus "World"
set message to greeting plus "!"
print text " String concatenation:"
print text " Result: Hello World!"
print text ""

# Feature 5: Comparison Operations
print text "Feature 5: Type-Checked Comparisons"
print text "-----------------------------------"
if integer_val is greater than 40
 print text " Comparison: 42 > 40 is true"

if float_val is less than 4
 print text " Comparison: 3.14159 < 4 is true"

print text ""

# Feature 6: Boolean Logic
print text "Feature 6: Type-Safe Boolean Logic"
print text "----------------------------------"
set condition_a to true
set condition_b to false
if condition_a and not condition_b
 print text " Boolean logic: (true AND NOT false) = true"

print text ""

print text "=========================================="
print text "All Type System Features Working!"
print text "=========================================="
print text ""
print text "Summary:"
print text " Type inference for variables"
print text " Type-safe arithmetic operators"
print text " Typed function parameters"
print text " String type operations"
print text " Type-checked comparisons"
print text " Boolean type operations"
print text ""
print text "Type checking is now fully integrated!"
