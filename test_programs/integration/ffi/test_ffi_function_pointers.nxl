# Test FFI Function Pointer Types
# Demonstrates function pointer type declarations and usage

# Test 1: Function pointer as typedef
extern type CompareFunc as function with Integer, Integer returns Integer

# Test 2: Declare a function that takes function pointer
extern function apply_operation with a as Integer, b as Integer, op as CompareFunc returns Integer from library "c"

# Test 3: Function pointer variable declaration  
function add with x as Integer, y as Integer returns Integer
    return x plus y
end

function subtract with x as Integer, y as Integer returns Integer
    return x minus y
end

function multiply with x as Integer, y as Integer returns Integer
    return x times y
end

# Test 4: Use function pointers with C stdlib
extern function qsort with base as Pointer, nitems as Integer, size as Integer, compar as function with Pointer, Pointer returns Integer from library "c"

function compare_ints with a_ptr as Pointer, b_ptr as Pointer returns Integer
    # Dereference void* pointers to get integers
    set a to dereference a_ptr as Integer
    set b to dereference b_ptr as Integer
    
    if a is less than b
        return -1
    else if a is greater than b
        return 1
    else
        return 0
    end
end

# Test 5: Signal handler (function pointer callback)
extern function signal with signum as Integer, handler as function with Integer returns Void from library "c"

function signal_handler with sig as Integer returns Void
    call printf with "Caught signal %d\n", sig
    return
end

# Test 6: Generic function pointer operations
set operation_ptr to address of add

# Test 7: Function pointer array
extern type FunctionArray as array of function with Integer, Integer returns Integer

print text "Function pointer tests complete"
