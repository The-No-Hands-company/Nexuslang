# Complete list comprehension test - all features
# Tests actual array iteration, conditions, different sizes

# Test 1: Basic mapping - double all numbers
set numbers to [1, 2, 3, 4, 5]
set doubled to [x times 2 for x in numbers]
print text "Test 1 - Doubled [1,2,3,4,5]:"
set i to 0
while i is less than 5
    print text doubled[i]
    set i to i plus 1
end

# Test 2: Filter with condition - only even numbers
set evens to [x for x in numbers if x modulo 2 is equal to 0]
print text "Test 2 - Evens from [1,2,3,4,5]: [2,4]"
set i to 0
while i is less than 2
    print text evens[i]
    set i to i plus 1
end

# Test 3: Different array size
set small to [10, 20]
set incremented to [x plus 1 for x in small]
print text "Test 3 - Incremented [10,20]:"
set j to 0
while j is less than 2
    print text incremented[j]
    set j to j plus 1
end

# Test 4: Nested operations
set values to [5, 10, 15]
set transformed to [x times 2 plus 1 for x in values]
print text "Test 4 - Transform [5,10,15] -> x*2+1:"
set k to 0
while k is less than 3
    print text transformed[k]
    set k to k plus 1
end
