# Test union type size calculation
# Verifies that unions use correct largest field size, not hardcoded i64

# Test 1: Small union (all fields fit in i8)
union SmallUnion
    tiny as Byte       # i8 - 8 bits
    flag as Boolean    # i1 - 1 bit
end

# Test 2: Medium union (needs i32)
union MediumUnion
    small_int as Short    # i16 - 16 bits
    regular_int as Integer # i64 - 64 bits
end

# Test 3: Large union (needs i64)
union LargeUnion
    big_int as Long       # i64 - 64 bits
    float_val as Float    # double - 64 bits
    ptr as Pointer        # i8* - 64 bits
end

# Test 4: Union with struct (needs byte array for large size)
struct BigStruct
    x as Integer
    y as Integer
    z as Integer
end

union MixedUnion
    num as Integer        # i64 - 64 bits
    big as BigStruct      # %BigStruct* - pointer is 64 bits
end

print text "Testing union size calculations:"
print text "SmallUnion should be i8 (1 byte)"
print text "MediumUnion should be i64 (8 bytes)" 
print text "LargeUnion should be i64 (8 bytes)"
print text "MixedUnion should be i64 (8 bytes for pointer)"
print text "All unions compiled successfully with correct sizes!"
