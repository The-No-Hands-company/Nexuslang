# Test bitwise operations

# Test 1: Bitwise AND (5 & 3 = 1)
set a to 5
set b to 3
set result to a bitwise and b
print text result

# Test 2: Bitwise OR (5 | 3 = 7)
set result to a bitwise or b
print text result

# Test 3: Bitwise XOR (5 ^ 3 = 6)
set result to a bitwise xor b
