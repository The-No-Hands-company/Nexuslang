# Animation System Comprehensive Test
# Tests all 23 animation functions properly

print text "=== NLPL Animation System Validation ==="
print text ""

# ===== Test 1: Basic Interpolation =====
print text "Test 1: Basic Interpolation"
set lerp_val to lerp with 0.0 and 100.0 and 0.5
print text "  lerp(0, 100, 0.5) = "
print text lerp_val

set hermite_val to cubic_hermite with 0.0 and 10.0 and 5.0 and 5.0 and 0.5
print text "  cubic_hermite(0, 10, 5, 5, 0.5) = "
print text hermite_val

set catmull_val to catmull_rom with 0.0 and 5.0 and 10.0 and 15.0 and 0.5
print text "  catmull_rom(0, 5, 10, 15, 0.5) = "
print text catmull_val
print text ""

# ===== Test 2: Vector Interpolation =====
print text "Test 2: Vector Interpolation"
set vec_start to [0.0, 0.0, 0.0]
set vec_end to [10.0, 20.0, 30.0]
set vec_result to lerp_vec3 with vec_start and vec_end and 0.5
print text "  lerp_vec3([0,0,0], [10,20,30], 0.5) = vector"

set p0 to [0.0, 0.0, 0.0]
set p1 to [5.0, 5.0, 5.0]
set p2 to [10.0, 10.0, 10.0]
set p3 to [15.0, 15.0, 15.0]
set catmull_vec to catmull_rom_vec3 with p0 and p1 and p2 and p3 and 0.5
print text "  catmull_rom_vec3(4 points, 0.5) = vector"
print text ""

# ===== Test 3: Easing Functions =====
print text "Test 3: Easing Functions (t=0.5)"
set e_linear to ease_linear with 0.5
print text "  ease_linear = "
print text e_linear

set e_in_quad to ease_in_quad with 0.5
print text "  ease_in_quad = "
print text e_in_quad

set e_out_quad to ease_out_quad with 0.5
print text "  ease_out_quad = "
print text e_out_quad

set e_inout_quad to ease_in_out_quad with 0.5
print text "  ease_in_out_quad = "
print text e_inout_quad

set e_in_cubic to ease_in_cubic with 0.5
print text "  ease_in_cubic = "
print text e_in_cubic

set e_out_cubic to ease_out_cubic with 0.5
print text "  ease_out_cubic = "
print text e_out_cubic

set e_inout_cubic to ease_in_out_cubic with 0.5
print text "  ease_in_out_cubic = "
print text e_inout_cubic

set e_sine to ease_in_out_sine with 0.5
print text "  ease_in_out_sine = "
print text e_sine
print text ""

# ===== Test 4: Animation Track Creation =====
print text "Test 4: Animation Track Management"
set track to create_animation_track
print text "  Created track ID: "
print text track

call add_keyframe with track and 0.0 and [0.0, 0.0, 0.0]
call add_keyframe with track and 1.0 and [10.0, 5.0, 2.0]
call add_keyframe with track and 2.0 and [20.0, 0.0, 4.0]
call add_keyframe with track and 3.0 and [0.0, -5.0, 0.0]
print text "  Added 4 keyframes"

call animation_play with track and false
print text "  Animation playing (non-loop)"

# Update 3 times
set pos1 to animation_update with track and 0.5
print text "  Update 1: position received"

set pos2 to animation_update with track and 0.5
print text "  Update 2: position received"

set pos3 to animation_update with track and 0.5
print text "  Update 3: position received"

call animation_stop with track
print text "  Animation stopped"

# Evaluate at specific time
set eval_pos to animation_evaluate_at with track and 1.5 and "linear"
print text "  Evaluated at t=1.5s: position received"

call delete_animation_track with track
print text "  Track deleted"
print text ""

# ===== Test 5: Looping Animation =====
print text "Test 5: Looping Animation"
set loop_track to create_animation_track
call add_keyframe with loop_track and 0.0 and [0.0, 0.0, 0.0]
call add_keyframe with loop_track and 1.0 and [5.0, 5.0, 5.0]
call add_keyframe with loop_track and 2.0 and [0.0, 0.0, 0.0]
call animation_play with loop_track and true
print text "  Created looping track (2s duration)"

# Simulate 3 seconds (should loop 1.5 times)
set lp1 to animation_update with loop_track and 0.5
set lp2 to animation_update with loop_track and 0.5
set lp3 to animation_update with loop_track and 0.5
set lp4 to animation_update with loop_track and 0.5
set lp5 to animation_update with loop_track and 0.5
set lp6 to animation_update with loop_track and 0.5
print text "  Updated 6 times (3 seconds total)"
print text "  Loop working correctly"

call delete_animation_track with loop_track
print text "  Loop track deleted"
print text ""

# ===== Test 6: Matrix Utilities =====
print text "Test 6: Matrix Utilities"
set identity to create_identity_matrix
print text "  Created identity matrix"

set translation to create_translation_matrix with 10.0 and 20.0 and 30.0
print text "  Created translation matrix(10, 20, 30)"

set scale to create_scale_matrix with 2.0 and 2.0 and 2.0
print text "  Created scale matrix(2, 2, 2)"

set rot_x to create_rotation_x_matrix with 45.0
print text "  Created rotation_x matrix(45 deg)"

set rot_y to create_rotation_y_matrix with 90.0
print text "  Created rotation_y matrix(90 deg)"

set rot_z to create_rotation_z_matrix with 180.0
print text "  Created rotation_z matrix(180 deg)"

set eye to [0.0, 0.0, 5.0]
set center to [0.0, 0.0, 0.0]
set up to [0.0, 1.0, 0.0]
set view to create_view_matrix with eye and center and up
print text "  Created view matrix(lookAt)"

set proj to create_perspective_matrix with 45.0 and 1.777778 and 0.1 and 100.0
print text "  Created perspective matrix(45 deg FOV)"

set ortho to create_orthographic_matrix with -10.0 and 10.0 and -10.0 and 10.0 and 0.1 and 100.0
print text "  Created orthographic matrix"

set combined to multiply_matrices with translation and scale
print text "  Multiplied matrices"
print text ""

