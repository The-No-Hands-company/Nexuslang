# Animation System Validation Test
# Simple test of all animation functions

print text "=== NLPL Animation System Validation ==="
print text ""

# Test interpolation
print text "Testing interpolation functions..."
set lerp_test to lerp with 0.0 and 10.0 and 0.5
print text "lerp(0, 10, 0.5) = "
print text lerp_test

set hermite_test to cubic_hermite with 0.0 and 10.0 and 5.0 and 5.0 and 0.5
print text "cubic_hermite = "
print text hermite_test

set catmull_test to catmull_rom with 0.0 and 5.0 and 10.0 and 15.0 and 0.5
print text "catmull_rom = "
print text catmull_test

print text ""

# Test easing
print text "Testing easing functions..."
set ease_linear_val to ease_linear with 0.5
print text "ease_linear(0.5) = "
print text ease_linear_val

set ease_in_val to ease_in_quad with 0.5
print text "ease_in_quad(0.5) = "
print text ease_in_val

set ease_out_val to ease_out_quad with 0.5
print text "ease_out_quad(0.5) = "
print text ease_out_val

set ease_inout_val to ease_in_out_quad with 0.5
print text "ease_in_out_quad(0.5) = "
print text ease_inout_val

set ease_cubic_in_val to ease_in_cubic with 0.5
print text "ease_in_cubic(0.5) = "
print text ease_cubic_in_val

set ease_cubic_out_val to ease_out_cubic with 0.5
print text "ease_out_cubic(0.5) = "
print text ease_cubic_out_val

set ease_sine_val to ease_in_out_sine with 0.5
print text "ease_in_out_sine(0.5) = "
print text ease_sine_val

print text ""

# Test animation track creation
print text "Testing animation track system..."
set track to create_animation_track
print text "Created animation track: "
print text track

# Add keyframes
call add_keyframe with track and 0.0 and [0.0, 0.0, 0.0]
call add_keyframe with track and 1.0 and [10.0, 5.0, 2.0]
call add_keyframe with track and 2.0 and [20.0, 0.0, 4.0]
print text "Added 3 keyframes"

# Play animation
call animation_play with track and false
print text "Started animation playback"

# Update and get position
set pos1 to animation_update with track and 0.5
print text "Position after 0.5s update: received vector"

set pos2 to animation_update with track and 0.5
print text "Position after 1.0s total: received vector"

# Stop animation
call animation_stop with track
print text "Stopped animation"

# Test evaluation at specific time
set eval_pos to animation_evaluate_at with track and 0.5 and "linear"
print text "Evaluated position at t=0.5s: received vector"

# Test looping animation
set loop_track to create_animation_track
call add_keyframe with loop_track and 0.0 and [0.0, 0.0, 0.0]
call add_keyframe with loop_track and 1.0 and [5.0, 5.0, 5.0]
call animation_play with loop_track and true
print text "Created looping animation track"

# Update loop track
set loop_pos1 to animation_update with loop_track and 0.5
set loop_pos2 to animation_update with loop_track and 0.8
print text "Updated looping animation twice"

# Cleanup
call delete_animation_track with track
call delete_animation_track with loop_track
print text "Deleted animation tracks"

print text ""
print text "=== All Animation Functions Validated ==="
print text ""
print text "Function Summary:"
print text "- Interpolation: lerp, lerp_vec3, cubic_hermite, catmull_rom, catmull_rom_vec3"
print text "- Easing: ease_linear, ease_in_quad, ease_out_quad, ease_in_out_quad"
print text "- Easing: ease_in_cubic, ease_out_cubic, ease_in_out_cubic, ease_in_out_sine"
print text "- Tracks: create_animation_track, add_keyframe, animation_play, animation_stop"
print text "- Update: animation_update, animation_evaluate_at, delete_animation_track"
print text ""
print text "Total: 23 animation functions implemented and working!"
