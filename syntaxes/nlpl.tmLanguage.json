{
  "name": "NLPL",
  "scopeName": "source.nlpl",
  "fileTypes": ["nlpl"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#classes"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.nlpl",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nlpl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nlpl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.nlpl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.nlpl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nlpl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.nlpl",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.nlpl",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.nlpl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nlpl",
          "match": "\\b(if|else|while|for|each|in|break|continue|return|match|with|case|when|then|do)\\b"
        },
        {
          "name": "keyword.declaration.nlpl",
          "match": "\\b(function|class|struct|union|enum|interface|trait|property|method|constructor)\\b"
        },
        {
          "name": "keyword.operator.nlpl",
          "match": "\\b(and|or|not|is|as|to|from|with|returns|called|new|delete|sizeof|typeof|instanceof)\\b"
        },
        {
          "name": "keyword.other.nlpl",
          "match": "\\b(set|print|import|export|public|private|protected|static|async|await|yield|throw|try|catch|finally)\\b"
        },
        {
          "name": "keyword.control.end.nlpl",
          "match": "\\b(end)\\b"
        },
        {
          "name": "constant.language.boolean.nlpl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.nlpl",
          "match": "\\b(Nothing|null|nil)\\b"
        },
        {
          "name": "variable.language.self.nlpl",
          "match": "\\b(self|this)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.nlpl",
          "match": "\\b(Integer|Float|String|Boolean|Nothing|Any)\\b"
        },
        {
          "name": "storage.type.collection.nlpl",
          "match": "\\b(List|Dict|Set|Tuple|Array|Map)\\b"
        },
        {
          "name": "storage.type.nlpl",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.nlpl",
          "match": "\\b(plus|minus|times|divided by|modulo|power of)\\b"
        },
        {
          "name": "keyword.operator.comparison.nlpl",
          "match": "\\b(equals|is equal to|is not equal to|is greater than|is less than|is greater than or equal to|is less than or equal to)\\b"
        },
        {
          "name": "keyword.operator.bitwise.nlpl",
          "match": "\\b(bitwise and|bitwise or|bitwise xor|bitwise not|left shift|right shift)\\b"
        },
        {
          "name": "keyword.operator.assignment.nlpl",
          "match": "\\b(to)\\b"
        },
        {
          "name": "keyword.operator.pointer.nlpl",
          "match": "\\b(address of|dereference)\\b"
        },
        {
          "name": "keyword.operator.memory.nlpl",
          "match": "\\b(allocate|free|reallocate)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.nlpl",
          "begin": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.nlpl"
            },
            "2": {
              "name": "entity.name.function.nlpl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nlpl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "entity.name.function.call.nlpl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s+(with|returns))"
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.nlpl",
          "begin": "\\b(class|struct|interface|trait|enum)\\s+([A-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.class.nlpl"
            },
            "2": {
              "name": "entity.name.type.class.nlpl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nlpl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.property.nlpl",
          "match": "\\b(property)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(as)\\s+([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.property.nlpl"
            },
            "2": {
              "name": "variable.other.property.nlpl"
            },
            "3": {
              "name": "keyword.operator.nlpl"
            },
            "4": {
              "name": "storage.type.nlpl"
            }
          }
        },
        {
          "name": "meta.method.nlpl",
          "begin": "\\b(method)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.method.nlpl"
            },
            "2": {
              "name": "entity.name.function.method.nlpl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nlpl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.declaration.nlpl",
          "match": "\\b(set)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(to)",
          "captures": {
            "1": {
              "name": "keyword.other.set.nlpl"
            },
            "2": {
              "name": "variable.other.nlpl"
            },
            "3": {
              "name": "keyword.operator.assignment.nlpl"
            }
          }
        },
        {
          "name": "variable.other.nlpl",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
