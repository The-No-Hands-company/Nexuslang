{
  "name": "NexusLang",
  "scopeName": "source.nxl",
  "fileTypes": ["nlpl"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#classes"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.nxl",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nxl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nxl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.nxl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.nxl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nxl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.hex.nxl",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.nxl",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.nxl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nxl",
          "match": "\\b(if|else|while|for|each|in|break|continue|return|match|with|case|when|then|do)\\b"
        },
        {
          "name": "keyword.declaration.nxl",
          "match": "\\b(function|class|struct|union|enum|interface|trait|property|method|constructor)\\b"
        },
        {
          "name": "keyword.operator.nxl",
          "match": "\\b(and|or|not|is|as|to|from|with|returns|called|new|delete|sizeof|typeof|instanceof)\\b"
        },
        {
          "name": "keyword.other.nxl",
          "match": "\\b(set|print|import|export|public|private|protected|static|async|await|yield|throw|try|catch|finally)\\b"
        },
        {
          "name": "keyword.control.end.nxl",
          "match": "\\b(end)\\b"
        },
        {
          "name": "constant.language.boolean.nxl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.nxl",
          "match": "\\b(Nothing|null|nil)\\b"
        },
        {
          "name": "variable.language.self.nxl",
          "match": "\\b(self|this)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.nxl",
          "match": "\\b(Integer|Float|String|Boolean|Nothing|Any)\\b"
        },
        {
          "name": "storage.type.collection.nxl",
          "match": "\\b(List|Dict|Set|Tuple|Array|Map)\\b"
        },
        {
          "name": "storage.type.nxl",
          "match": "\\b([A-Z][a-zA-Z0-9]*)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.nxl",
          "match": "\\b(plus|minus|times|divided by|modulo|power of)\\b"
        },
        {
          "name": "keyword.operator.comparison.nxl",
          "match": "\\b(equals|is equal to|is not equal to|is greater than|is less than|is greater than or equal to|is less than or equal to)\\b"
        },
        {
          "name": "keyword.operator.bitwise.nxl",
          "match": "\\b(bitwise and|bitwise or|bitwise xor|bitwise not|left shift|right shift)\\b"
        },
        {
          "name": "keyword.operator.assignment.nxl",
          "match": "\\b(to)\\b"
        },
        {
          "name": "keyword.operator.pointer.nxl",
          "match": "\\b(address of|dereference)\\b"
        },
        {
          "name": "keyword.operator.memory.nxl",
          "match": "\\b(allocate|free|reallocate)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.nxl",
          "begin": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.nxl"
            },
            "2": {
              "name": "entity.name.function.nxl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nxl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "entity.name.function.call.nxl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s+(with|returns))"
        }
      ]
    },
    "classes": {
      "patterns": [
        {
          "name": "meta.class.nxl",
          "begin": "\\b(class|struct|interface|trait|enum)\\s+([A-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.class.nxl"
            },
            "2": {
              "name": "entity.name.type.class.nxl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nxl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.property.nxl",
          "match": "\\b(property)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(as)\\s+([A-Z][a-zA-Z0-9]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.property.nxl"
            },
            "2": {
              "name": "variable.other.property.nxl"
            },
            "3": {
              "name": "keyword.operator.nxl"
            },
            "4": {
              "name": "storage.type.nxl"
            }
          }
        },
        {
          "name": "meta.method.nxl",
          "begin": "\\b(method)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.method.nxl"
            },
            "2": {
              "name": "entity.name.function.method.nxl"
            }
          },
          "end": "\\b(end)\\b",
          "endCaptures": {
            "1": {
              "name": "keyword.control.end.nxl"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.declaration.nxl",
          "match": "\\b(set)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(to)",
          "captures": {
            "1": {
              "name": "keyword.other.set.nxl"
            },
            "2": {
              "name": "variable.other.nxl"
            },
            "3": {
              "name": "keyword.operator.assignment.nxl"
            }
          }
        },
        {
          "name": "variable.other.nxl",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
