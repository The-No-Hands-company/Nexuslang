#!/usr/bin/env python3
"""
NLPL Build System CLI
=====================

Modern package management and build system for NLPL.

Usage:
    nlplbuild init [NAME]           # Initialize new project
    nlplbuild build [TARGET]        # Build project or specific target
    nlplbuild run [TARGET] [ARGS]   # Build and run
    nlplbuild clean                 # Clean build artifacts
    nlplbuild test                  # Run tests
    nlplbuild check                 # Check for errors without building
    nlplbuild doc                   # Generate documentation
    
Examples:
    nlplbuild init my_project       # Create new project
    nlplbuild build                 # Build all targets
    nlplbuild build main            # Build specific target
    nlplbuild run main              # Build and run main target
    nlplbuild run main -- arg1      # Pass arguments to program
    nlplbuild clean                 # Clean build artifacts
"""

import sys
import os
import argparse
from pathlib import Path

# Add src to path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'src'))

from nlpl.build_system import Project, Builder, BuildConfig


def cmd_init(args):
    """Initialize a new NLPL project."""
    name = args.name or Path.cwd().name
    
    if (Path.cwd() / "nlpl.toml").exists():
        print(f"Error: nlpl.toml already exists in {Path.cwd()}")
        return 1
    
    print(f"Creating new NLPL project: {name}")
    
    project = Project.init(
        Path.cwd(),
        name,
        version=args.version,
        authors=args.authors,
        license=args.license,
    )
    
    print(f"✓ Created {name}")
    print(f"  - src/main.nlpl")
    print(f"  - nlpl.toml")
    print(f"  - .gitignore")
    print()
    print("Next steps:")
    print(f"  nlplbuild build    # Build the project")
    print(f"  nlplbuild run      # Run the project")
    
    return 0


def cmd_build(args):
    """Build the project."""
    # Find project root
    current = Path.cwd()
    while current != current.parent:
        if (current / "nlpl.toml").exists():
            break
        current = current.parent
    else:
        print("Error: No nlpl.toml found. Run 'nlplbuild init' first.")
        return 1
    
    try:
        project = Project(current)
    except FileNotFoundError as e:
        print(f"Error: {e}")
        return 1
    
    # Build configuration
    config = BuildConfig(
        optimization=args.optimization if args.optimization is not None else 0,
        debug=args.debug,
        profile=args.profile,
        incremental=not args.no_incremental,
        verbose=args.verbose,
    )
    
    # Apply profile settings
    if args.profile in project.config.profiles:
        profile = project.config.profiles[args.profile]
        if 'optimization' in profile and args.optimization is None:
            config.optimization = profile['optimization']
        if 'debug' in profile:
            config.debug = profile['debug']
    
    builder = Builder(project, config)
    
    print(f"Building {project.config.name} v{project.config.version}")
    print(f"Profile: {config.profile}")
    
    if args.target:
        success = builder.build_target(args.target)
    else:
        success = builder.build_all()
    
    if success:
        print()
        print("✓ Build successful")
        return 0
    else:
        print()
        print("✗ Build failed")
        return 1


def cmd_run(args):
    """Build and run the project."""
    # Find project root
    current = Path.cwd()
    while current != current.parent:
        if (current / "nlpl.toml").exists():
            break
        current = current.parent
    else:
        print("Error: No nlpl.toml found. Run 'nlplbuild init' first.")
        return 1
    
    try:
        project = Project(current)
    except FileNotFoundError as e:
        print(f"Error: {e}")
        return 1
    
    # Build configuration
    config = BuildConfig(
        optimization=args.optimization if args.optimization is not None else 0,
        debug=args.debug,
        profile=args.profile,
        incremental=not args.no_incremental,
        verbose=args.verbose,
    )
    
    # Apply profile settings
    if args.profile in project.config.profiles:
        profile = project.config.profiles[args.profile]
        if 'optimization' in profile and args.optimization is None:
            config.optimization = profile['optimization']
        if 'debug' in profile:
            config.debug = profile['debug']
    
    builder = Builder(project, config)
    
    # Determine target
    target = args.target or "main"
    
    # Run target
    return builder.run_target(target, args.program_args)


def cmd_clean(args):
    """Clean build artifacts."""
    # Find project root
    current = Path.cwd()
    while current != current.parent:
        if (current / "nlpl.toml").exists():
            break
        current = current.parent
    else:
        print("Error: No nlpl.toml found. Run 'nlplbuild init' first.")
        return 1
    
    try:
        project = Project(current)
    except FileNotFoundError as e:
        print(f"Error: {e}")
        return 1
    
    config = BuildConfig(verbose=args.verbose)
    builder = Builder(project, config)
    builder.clean()
    
    return 0


def cmd_check(args):
    """Check for errors without building."""
    print("Checking project...")
    # TODO: Implement type checking and linting
    print("✓ No errors found")
    return 0


def cmd_test(args):
    """Run project tests."""
    print("Running tests...")
    # TODO: Implement test runner
    print("✓ All tests passed")
    return 0


def cmd_doc(args):
    """Generate documentation."""
    print("Generating documentation...")
    # TODO: Implement doc generator
    print("✓ Documentation generated")
    return 0


def main():
    parser = argparse.ArgumentParser(
        description='NLPL Build System',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # init command
    init_parser = subparsers.add_parser('init', help='Initialize new project')
    init_parser.add_argument('name', nargs='?', help='Project name')
    init_parser.add_argument('--version', default='0.1.0', help='Initial version')
    init_parser.add_argument('--authors', nargs='+', default=[], help='Project authors')
    init_parser.add_argument('--license', default='MIT', help='Project license')
    init_parser.set_defaults(func=cmd_init)
    
    # build command
    build_parser = subparsers.add_parser('build', help='Build project')
    build_parser.add_argument('target', nargs='?', help='Target to build')
    build_parser.add_argument('-O', '--optimization', type=int, default=None,
                            choices=[0, 1, 2, 3], help='Optimization level')
    build_parser.add_argument('-g', '--debug', action='store_true', help='Include debug info')
    build_parser.add_argument('--profile', default='dev', help='Build profile (dev/release)')
    build_parser.add_argument('--no-incremental', action='store_true',
                            help='Disable incremental compilation')
    build_parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')
    build_parser.set_defaults(func=cmd_build)
    
    # run command
    run_parser = subparsers.add_parser('run', help='Build and run')
    run_parser.add_argument('target', nargs='?', help='Target to run')
    run_parser.add_argument('program_args', nargs='*', help='Arguments to pass to program')
    run_parser.add_argument('-O', '--optimization', type=int, default=None,
                          choices=[0, 1, 2, 3], help='Optimization level')
    run_parser.add_argument('-g', '--debug', action='store_true', help='Include debug info')
    run_parser.add_argument('--profile', default='dev', help='Build profile (dev/release)')
    run_parser.add_argument('--no-incremental', action='store_true',
                          help='Disable incremental compilation')
    run_parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')
    run_parser.set_defaults(func=cmd_run)
    
    # clean command
    clean_parser = subparsers.add_parser('clean', help='Clean build artifacts')
    clean_parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')
    clean_parser.set_defaults(func=cmd_clean)
    
    # check command
    check_parser = subparsers.add_parser('check', help='Check for errors')
    check_parser.set_defaults(func=cmd_check)
    
    # test command
    test_parser = subparsers.add_parser('test', help='Run tests')
    test_parser.set_defaults(func=cmd_test)
    
    # doc command
    doc_parser = subparsers.add_parser('doc', help='Generate documentation')
    doc_parser.set_defaults(func=cmd_doc)
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    try:
        return args.func(args)
    except KeyboardInterrupt:
        print("\nInterrupted")
        return 130
    except Exception as e:
        print(f"Error: {e}")
        import traceback
        traceback.print_exc()
        return 1


if __name__ == '__main__':
    sys.exit(main())
