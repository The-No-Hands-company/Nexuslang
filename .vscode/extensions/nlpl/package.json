{
  "name": "nlpl-language-support",
  "displayName": "NLPL Language Support",
  "description": "Language support for NLPL (Natural Language Programming Language)",
  "version": "0.1.0",
  "publisher": "nlpl",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nlpl",
        "aliases": [
          "NLPL",
          "nlpl"
        ],
        "extensions": [
          ".nlpl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nlpl",
        "scopeName": "source.nlpl",
        "path": "./syntaxes/nlpl.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "NLPL",
      "properties": {
        "nlpl.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable NLPL Language Server"
        },
        "nlpl.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to NLPL language server (leave empty for auto-detect)"
        },
        "nlpl.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
